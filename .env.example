# S3 / R2 / OSS 兼容存储配置（可选后备配置）
# 若 KV 中已有并激活存储桶，可不填写下面这组。
S3_ENDPOINT=这里填你的节点地址，例如: https://s3.us-east-1.amazonaws.com
S3_REGION=这里写存储桶地域，如果是自定义OSS可以填 auto
S3_BUCKET=这里填你的存储桶名字
S3_ACCESS_KEY=这里填你的AccessKey
S3_SECRET_KEY=这里填你的SecretKey

# 管理员信息配置
ADMIN_USER=这里设置你的后台账号，例如: admin
ADMIN_PASS=这里设置你的后台密码
AUTH_SECRET=这里填至少16位随机字符串，用于会话签名（强制项，缺失将导致接口拒绝请求）
BUCKET_ENCRYPTION_KEY=这里填至少16位随机字符串，用于桶密钥加密（强制项）

# 桶配置存储后端：vercel 或 cloudflare
BUCKET_STORE_PROVIDER=vercel

# 方案 A：Vercel + Upstash Redis（KV 兼容，推荐）
# 代码会按以下优先级自动读取：
# URL: KV_REST_API_URL -> UPSTASH_REDIS_REST_URL
# 读 Token: KV_REST_API_READ_ONLY_TOKEN -> KV_REST_API_TOKEN -> UPSTASH_REDIS_REST_TOKEN
# 写 Token: KV_REST_API_TOKEN -> UPSTASH_REDIS_REST_TOKEN
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Upstash 自动注入变量（可直接用，不必手工映射）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash 连接串变量（本项目当前不直接使用，仅保留参考）
KV_URL=
REDIS_URL=

# 方案 B：Cloudflare KV
CF_ACCOUNT_ID=
CF_KV_NAMESPACE_ID=
CF_API_TOKEN=

# 自建服务器部署建议：
# 1) 推荐继续使用 Upstash/Cloudflare 作为外部 KV，部署平台不限。
# 2) 若使用自建 Redis，请提供 REST 兼容网关并通过 KV_REST_API_URL / KV_REST_API_TOKEN 接入。

# 可选：代理白名单域名（逗号分隔）；未配置时默认只允许 S3_ENDPOINT 对应域名
PROXY_ALLOWED_HOSTS=
